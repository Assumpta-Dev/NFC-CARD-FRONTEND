# ===========================================================
# FRONTEND ENVIRONMENT VARIABLES
# Copy to .env and fill in values. NEVER commit .env.
# In Vite, all variables MUST be prefixed with VITE_
# to be accessible in the browser (security measure).
# ===========================================================

# Backend API base URL
# In development: leave empty to use Vite's proxy (configured in vite.config.ts)
# In production: set to your deployed backend URL
VITE_API_URL=

# App name shown in browser tab and meta tags
VITE_APP_NAME=NFC Business Card
